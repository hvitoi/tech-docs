    {
      "id": "KsdJl-yOUqNryjNtqXQgB",
      "type": "text",
      "x": -7407.050514784399,
      "y": -3156.516398744039,
      "width": 1905.9166259765625,
      "height": 770,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffd8a8",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],

    {
      "id": "Ms2X3EEXx9VUuKZ540m-z",
      "type": "text",
      "x": 8247.997619311092,
      "y": 1486.474164039526,
      "width": 408,
      "height": 175,
      "angle": 0,
      "strokeColor": "#f76707",
      "backgroundColor": "transparent",
      "fillStyle": "solid",

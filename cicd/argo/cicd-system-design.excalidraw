      "versionNonce": 717363697,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780658311161,
      "link": null,
      "locked": false,
      "text": "Holds the status of each\nnode in the DAG in etcd\n\nNo processing queue, handled by\nK8S pod scheduler itself\n\nResource efficient, K8S will place it\nat the right node",
      "fontSize": 7.7142857142857215,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "Holds the status of each\nnode in the DAG in etcd\n\nNo processing queue, handled by\nK8S pod scheduler itself\n\nResource efficient, K8S will place it\nat the right node",
      "autoResize": true,
      "lineHeight": 1.25
    },

      "isDeleted": false,
      "boundElements": null,
      "updated": 1780672915316,
      "link": null,
      "locked": false,
      "text": "Non-functional Requirements\n- Autoscaling\n- 99.00% ~ 99.90%\n- Security: isolated environments\n- GitOps",
      "fontSize": 28,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non-functional Requirements\n- Autoscaling\n- 99.00% ~ 99.90%\n- Security: isolated environments\n- GitOps",
      "autoResize": true,
      "lineHeight": 1.25
    },
